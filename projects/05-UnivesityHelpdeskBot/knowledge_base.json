  "courses": {
    "CIS-101": {
      "title": "Programming Fundamentals",
      "description": "Introduction to programming using Python. Basic data types, control structures, functions, arrays, file handling.",
      "credit_hours": 3,
      "prerequisites": "None",
      "offered": "Fall, Spring",
      "lab_hours": 2,
      "assessment": "Quizzes (20%), Assignments (20%), Midterm (30%), Final (30%)"
    },
    "CIS-102": {
      "title": "Digital Logic Design",
      "description": "Number systems, Boolean algebra, logic gates, combinational and sequential circuits, basic computer organization.",
      "credit_hours": 3,
      "prerequisites": "None",
      "offered": "Fall",
      "lab_hours": 2,
      "assessment": "Quizzes (15%), Assignments (25%), Midterm (30%), Final (30%)"
    },
    "CIS-201": {
      "title": "Data Structures and Algorithms",
      "description": "Arrays, linked lists, stacks, queues, trees, graphs. Sorting and searching algorithms.",
      "credit_hours": 3,
      "prerequisites": "CIS-101",
      "offered": "Fall, Spring",
      "lab_hours": 2,
      "assessment": "Quizzes (20%), Assignments (20%), Midterm (30%), Final (30%)"
    },
    "CIS-202": {
      "title": "Computer Organization",
      "description": "Computer architecture, memory hierarchy, instruction sets, I/O systems, basic assembly language.",
      "credit_hours": 3,
      "prerequisites": "CIS-102",
      "offered": "Fall, Spring",
      "lab_hours": 2
    },
    "CIS-301": {
      "title": "Database Systems",
      "description": "Relational database design, SQL, normalization, transaction management, concurrency control.",
      "credit_hours": 3,
      "prerequisites": "CIS-201",
      "offered": "Fall, Spring",
      "lab_hours": 2,
      "assessment": "Quizzes (15%), Assignments (25%), Midterm (30%), Final (30%)"
    },
    "CIS-302": {
      "title": "Software Engineering",
      "description": "Software development lifecycle, requirements engineering, design patterns, testing, project management.",
      "credit_hours": 3,
      "prerequisites": "CIS-201",
      "offered": "Fall, Spring",
      "group_project": true
    },
    "CIS-401": {
      "title": "Computer Networks",
      "description": "OSI model, TCP/IP, routing algorithms, network security basics, wireless networks.",
      "credit_hours": 3,
      "prerequisites": "CIS-201",
      "offered": "Fall",
      "lab_hours": 2
    },
    "CIS-402": {
      "title": "Operating Systems",
      "description": "Process management, memory management, file systems, I/O systems, virtualization.",
      "credit_hours": 3,
      "prerequisites": "CIS-202",
      "offered": "Spring"
    },
    "CIS-403": {
      "title": "Artificial Intelligence",
      "description": "AI fundamentals, search algorithms, knowledge representation, reasoning, introduction to machine learning.",
      "credit_hours": 3,
      "prerequisites": "CIS-201, MATH-201",
      "offered": "Spring"
    },
    "CIS-404": {
      "title": "Cybersecurity Fundamentals",
      "description": "Cryptography, network security, ethical hacking, security policies, risk management.",
      "credit_hours": 3,
      "prerequisites": "CIS-401",
      "offered": "Spring"
    },
    "CIS-410": {
      "title": "Machine Learning",
      "description": "Supervised and unsupervised learning, regression, classification, clustering, neural networks.",
      "credit_hours": 3,
      "prerequisites": "CIS-403, MATH-202",
      "offered": "Fall",
      "project": true
    },
    "CIS-411": {
      "title": "Data Science",
      "description": "Data preprocessing, exploratory data analysis, visualization, big data technologies.",
      "credit_hours": 3,
      "prerequisites": "CIS-301, MATH-202",
      "offered": "Spring"
    },
    "CIS-490": {
      "title": "Capstone Project",
      "description": "Final year project integrating all CIS concepts. Industry collaboration encouraged.",
      "credit_hours": 6,
      "prerequisites": "Senior standing, CIS-301",
      "offered": "Fall, Spring",
      "duration": "2 semesters"
    }
  },

